# Frontend (Vite)
VITE_API_URL=http://localhost:3001/api
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend (Express) — copy these to .env at repo root; `npm run dev` loads them for both sides
NODE_ENV=development
PORT=3001
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# OMR conversion service (FastAPI + Audiveris)
OMR_SERVICE_URL=http://127.0.0.1:8000
AUDIVERIS_BIN=/Applications/Audiveris.app/Contents/MacOS/Audiveris
OMR_TEST_MAX_PAGES=all
