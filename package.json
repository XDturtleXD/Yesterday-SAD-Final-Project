{
  "name": "yesterday",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"vite\" \"npm run dev --prefix backend\"",
    "dev:all": "concurrently -n frontend,backend,omr -c cyan,magenta,green \"vite\" \"npm run dev --prefix backend\" \"npm run dev:omr\"",
    "dev:frontend": "vite",
    "dev:backend": "npm run dev --prefix backend",
    "dev:omr": "cd services/omr && if [ -x .venv/bin/python ]; then .venv/bin/python -m uvicorn main:app --reload --port 8000; else python3 -m uvicorn main:app --reload --port 8000; fi",
    "postinstall": "npm install --prefix backend",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "opensheetmusicdisplay": "^1.9.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
